# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/scheduler

# Twilio (dummy credentials)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15555551234

# Public URL for callbacks (ngrok or host)
PUBLIC_URL=https://example.ngrok.io

# Redis for background jobs
REDIS_URL=redis://redis:6379/0

# Security (optional; if set, lead webhook requires X-Signature: sha256=<hmac_hex>)
WEBHOOK_SECRET=replace-with-secret

# Google Calendar (optional; path to service account JSON)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json